+/**
+ * Create a billing alert for workqueue items. These alerts are used for billing
+ * reporting and downstream workflows. Alerts are created when workqueue items
+ * are deferred or resolved so that billing reports capture these actions.
+ */
+async function createBillingAlert(params: {
+  organizationId: string;
+  workqueueItemId: string;
+  alertType: string;
+  title: string;
+  description: string | null;
+  severity?: string;
+  alertStatus?: string;
+  dueDate?: string | null;
+  userId?: string | null;
+}) {
+  const supabase = createServerSupabaseAdminClient();
+  if (!supabase) throw new Error("Database connection not available");
+  const severity = params.severity ?? "info";
+  const alertStatus = params.alertStatus ?? "open";
+  const { error } = await supabase.from("billing_alerts").insert({
+    organization_id: params.organizationId,
+    workqueue_item_id: params.workqueueItemId,
+    alert_type: params.alertType,
+    severity,
+    alert_status: alertStatus,
+    title: params.title,
+    description: params.description,
+    due_date: params.dueDate ?? null,
+    created_at: new Date().toISOString(),
+    updated_at: new Date().toISOString(),
+    context_payload: {},
+  });
+  if (error) throw new Error(error.message);
+}
