{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/{page,layout,template,loading,error,not-found,route,default}.{ts,tsx}",
    "scripts/**/*.ts",
    "lib/**/__tests__/**/*.test.ts",
    "app/**/__tests__/**/*.test.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "types/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "ignore": [
    "supabase/functions/**"
  ],
  "ignoreDependencies": [
    "@tailwindcss/postcss",
    "tailwindcss",
    "server-only",
    "undici"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "error",
    "duplicates": "error",
    "unresolved": "error",
    "binaries": "error",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "enumMembers": "off"
  }
}
